# Server port (default 8473 — change if this port is already in use)
PORT=8473

# Where notes are stored inside the container (default: ./data/notes)
# With docker-compose, /app/data is persisted via the notes-data volume.
# NOTES_DATA_DIR=/app/data/notes

# Replicate API token for AI image enhancement (Real-ESRGAN)
# Get yours at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here
